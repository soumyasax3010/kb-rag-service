# Copy to .env and fill in.
#
# The OpenAI SDK talks to any OpenAI-compatible endpoint. Examples:
#   OpenAI:    leave OPENAI_BASE_URL unset, EMBED_MODEL=text-embedding-3-small (1536-dim)
#   Fireworks: OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
#              EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5 (768-dim)
OPENAI_API_KEY=fw_...
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
DATABASE_URL=postgresql+asyncpg://kb:kb@localhost:5432/kb

EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_DIM=768
CHAT_MODEL=accounts/fireworks/models/glm-5p2

CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

TOP_K=5
